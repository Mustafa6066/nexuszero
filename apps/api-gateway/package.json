{
  "name": "@nexuszero/api-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@nexuszero/shared": "workspace:*",
    "@nexuszero/db": "workspace:*",
    "@nexuszero/queue": "workspace:*",
    "@nexuszero/llm-router": "workspace:*",
    "@nexuszero/prober": "workspace:*",
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/s3-request-presigner": "^3.400.0",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.4.0",
    "@hono/node-server": "^1.11.0",
    "graphql": "^16.8.0",
    "graphql-yoga": "^5.3.0",
    "@pothos/core": "^3.41.0",
    "@pothos/plugin-relay": "^3.46.0",
    "@pothos/plugin-validation": "^3.10.0",
    "@pothos/plugin-scope-auth": "^3.21.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.3",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/ws": "^8.5.10",
    "tsx": "^4.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
