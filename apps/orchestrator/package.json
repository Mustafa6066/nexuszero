{
  "name": "@nexuszero/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@nexuszero/shared": "workspace:*",
    "@nexuszero/db": "workspace:*",
    "@nexuszero/queue": "workspace:*",
    "@nexuszero/brain": "workspace:*",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.4.0",
    "@hono/node-server": "^1.11.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
