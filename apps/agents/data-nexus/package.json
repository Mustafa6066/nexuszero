{
  "name": "@nexuszero/data-nexus-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./clickhouse-client": {
      "types": "./dist/clickhouse-client.d.ts",
      "import": "./dist/clickhouse-client.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../../.env src/index.ts",
    "build": "tsup src/index.ts src/clickhouse-client.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@nexuszero/shared": "workspace:*",
    "@nexuszero/db": "workspace:*",
    "@nexuszero/queue": "workspace:*",
    "@anthropic-ai/sdk": "^0.24.0",
    "@clickhouse/client": "^1.1.0",
    "drizzle-orm": "^0.30.10",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "tsx": "^4.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
