{
  "name": "@nexuszero/ad-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@nexuszero/shared": "workspace:*",
    "@nexuszero/db": "workspace:*",
    "@nexuszero/queue": "workspace:*",
    "@anthropic-ai/sdk": "^0.24.0",
    "drizzle-orm": "^0.30.10",
    "openai": "^4.47.0",
    "ioredis": "^5.4.1",
    "@aws-sdk/client-s3": "^3.577.0"
  },
  "devDependencies": {
    "tsx": "^4.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
