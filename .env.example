# ─── Database ───
DATABASE_URL=postgresql://nexuszero:localdev@localhost:5432/nexuszero
DATABASE_PRIVATE_URL=postgresql://nexuszero:localdev@postgres:5432/nexuszero

# ─── Redis ───
REDIS_URL=redis://localhost:6379
# Use REDIS_PRIVATE_URL on Railway services for internal Redis traffic.
REDIS_PRIVATE_URL=redis://redis:6379

# ─── Confluent Cloud Kafka ───
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-west-2.aws.confluent.cloud:9092
CONFLUENT_API_KEY=
CONFLUENT_API_SECRET=

# ─── ClickHouse ───
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Cloudflare R2 ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexuszero-assets
R2_PUBLIC_URL=

# ─── Auth ───
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
NEXTAUTH_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Dashboard ───
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Encryption ───
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── LLM APIs ───
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ─── Creative APIs ───
STABILITY_API_KEY=sk-xxx
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─── Meta ───
META_APP_ID=
META_APP_SECRET=

# ─── LinkedIn ───
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── HubSpot ───
HUBSPOT_API_KEY=

# ─── Salesforce ───
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# ─── Email ───
RESEND_API_KEY=

# ─── Observability ───
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=nexuszero
BETTERSTACK_TOKEN=

# ─── App ───
NODE_ENV=development
PORT=4000
DASHBOARD_URL=http://localhost:3000
API_URL=http://localhost:4000
LOG_LEVEL=debug
